# Firebase-Konfiguration (aus der Firebase-Konsole kopieren)
# Diese Datei als ".env" speichern und die Werte eintragen.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=mein-projekt.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mein-projekt
